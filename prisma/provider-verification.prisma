model ProviderApplication {
  providerId      String    @id @db.Uuid
  ownerUserId     String    @db.Uuid
  providerMode    String    @db.VarChar(60)
  legalName       String    @db.VarChar(220)
  publicPhone     String?   @db.VarChar(16)
  privatePhone    String    @db.VarChar(16)
  description     String?   @db.Text
  status          String    @default("DRAFT") @db.VarChar(40)
  submittedAt     DateTime? @db.Timestamptz(6)
  reviewedAt      DateTime? @db.Timestamptz(6)
  reviewedByUserId String?  @db.Uuid
  reviewReason    String?   @db.Text
  appealStatus    String?   @db.VarChar(40)
  appealReason    String?   @db.Text
  appealedAt      DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  @@index([ownerUserId, status], map: "ProviderApplication_owner_status_idx")
  @@index([status, submittedAt], map: "ProviderApplication_status_submitted_idx")
}

model ProviderDocument {
  id               String    @id @default(uuid()) @db.Uuid
  providerId       String    @db.Uuid
  ownerUserId      String    @db.Uuid
  fileAssetId      String    @unique @db.Uuid
  documentType     String    @db.VarChar(80)
  expiresAt        DateTime? @db.Timestamptz(6)
  status           String    @default("PENDING_REVIEW") @db.VarChar(40)
  reviewReason     String?   @db.Text
  reviewedAt       DateTime? @db.Timestamptz(6)
  reviewedByUserId String?   @db.Uuid
  appealStatus     String?   @db.VarChar(40)
  appealReason     String?   @db.Text
  appealedAt       DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)

  @@index([providerId, status], map: "ProviderDocument_provider_status_idx")
  @@index([expiresAt, status], map: "ProviderDocument_expiry_status_idx")
}
