// Provider-neutral customer identity verification attempts.
// SensitiveIdentity in schema.prisma holds only HMAC/encrypted national ID values.

model IdentityVerificationAttempt {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  providerKey        String    @db.VarChar(60)
  status             String    @db.VarChar(40)
  nationalIdHmac     String    @db.VarChar(128)
  mobileHmac         String    @db.VarChar(128)
  nameFingerprint    String    @db.VarChar(128)
  providerReference  String?   @db.VarChar(180)
  decisionReasonCode String?   @db.VarChar(100)
  submittedAt        DateTime  @db.Timestamptz(6)
  decidedAt          DateTime? @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId, createdAt(sort: Desc)], map: "IdentityVerificationAttempt_user_created_idx")
  @@index([status, createdAt(sort: Desc)], map: "IdentityVerificationAttempt_status_created_idx")
  @@index([nationalIdHmac], map: "IdentityVerificationAttempt_national_hmac_idx")
}
