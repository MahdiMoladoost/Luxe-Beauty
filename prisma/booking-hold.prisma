enum BookingHoldStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  RELEASED
}

model BookingHold {
  id                String            @id @default(uuid()) @db.Uuid
  customerUserId    String            @db.Uuid
  quoteId           String            @db.Uuid
  offeringId        String            @db.Uuid
  providerId        String            @db.Uuid
  branchId          String?           @db.Uuid
  professionalId    String?           @db.Uuid
  resourceType      ScheduleOwnerType
  resourceId        String            @db.Uuid
  startsAt          DateTime          @db.Timestamptz(6)
  endsAt            DateTime          @db.Timestamptz(6)
  occupiedFrom      DateTime          @db.Timestamptz(6)
  occupiedUntil     DateTime          @db.Timestamptz(6)
  status            BookingHoldStatus @default(ACTIVE)
  expiresAt         DateTime          @db.Timestamptz(6)
  idempotencyKey    String            @db.VarChar(160)
  requestHash       String            @db.VarChar(128)
  snapshot          Json
  consumedBookingId String?           @unique(map: "BookingHold_consumedBookingId_key") @db.Uuid
  releasedAt        DateTime?         @db.Timestamptz(6)
  createdAt         DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @db.Timestamptz(6)

  @@unique([customerUserId, idempotencyKey], map: "BookingHold_customer_idempotency_key")
  @@index([resourceType, resourceId, status, expiresAt], map: "BookingHold_resource_status_expiry_idx")
  @@index([customerUserId, status, createdAt], map: "BookingHold_customer_status_created_idx")
  @@index([quoteId, createdAt], map: "BookingHold_quote_created_idx")
}
