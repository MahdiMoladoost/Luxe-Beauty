# Application
NODE_ENV=development
APP_ENV=development
APP_URL=http://localhost:5000
APP_PORT=5000
NEXT_PUBLIC_APP_URL=http://localhost:5000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://luxe:luxe_dev_password@localhost:5432/luxe_beauty?schema=public
DATABASE_DIRECT_URL=

# Redis / queues
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=luxe
WORKER_CONCURRENCY=5

# Authentication and cryptography (set strong unique values locally; never commit them)
AUTH_SECRET=
SESSION_COOKIE_NAME=luxe_session
SESSION_ABSOLUTE_TTL_SECONDS=2592000
SESSION_IDLE_TTL_SECONDS=604800
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MOBILE_WINDOW_SECONDS=900
OTP_MOBILE_WINDOW_LIMIT=5
OTP_IP_WINDOW_SECONDS=900
OTP_IP_WINDOW_LIMIT=20
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCK_SECONDS=900
PASSWORD_PEPPER=
NATIONAL_ID_HMAC_KEY=
PII_ENCRYPTION_KEY=
PII_ENCRYPTION_KEY_VERSION=v1

# Development/bootstrap seed
# The super-admin mobile is fixed by requirement to 09399496078.
# The initial password is read only from this environment variable and is never stored in Git.
ENABLE_DEVELOPMENT_SEED=true
SEED_SUPER_ADMIN_MOBILE=09399496078
SEED_SUPER_ADMIN_INITIAL_PASSWORD=
SEED_SUPER_ADMIN_FORCE_PASSWORD_CHANGE=true

# Identity verification
IDENTITY_PROVIDER=mock
IDENTITY_API_BASE_URL=
IDENTITY_API_KEY=

# Payments
PAYMENT_PROVIDER=mock
PAYMENT_API_BASE_URL=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=
PLATFORM_PAYMENT_MERCHANT_ID=

# SMS / Kavenegar
SMS_PROVIDER=mock
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=
KAVENEGAR_BOOKING_TEMPLATE=
KAVENEGAR_REMINDER_TEMPLATE=
KAVENEGAR_ATTENDANCE_TEMPLATE=

# Maps / Neshan
MAP_PROVIDER=mock
NESHAN_API_BASE_URL=
NESHAN_API_KEY=
NEXT_PUBLIC_NESHAN_MAP_KEY=

# Object storage (MinIO locally, S3-compatible in production)
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_MEDIA_BUCKET=luxe-public-media
S3_PRIVATE_DOCUMENTS_BUCKET=luxe-private-documents
S3_CONSULTATION_BUCKET=luxe-consultations
S3_REVIEW_MEDIA_BUCKET=luxe-review-media
S3_PORTFOLIO_MEDIA_BUCKET=luxe-portfolio-media
S3_SUPPORT_ATTACHMENTS_BUCKET=luxe-support-attachments
S3_TEMPORARY_UPLOADS_BUCKET=luxe-temporary-uploads
SIGNED_URL_TTL_SECONDS=300

# Malware scanning
MALWARE_SCAN_PROVIDER=mock
MALWARE_SCAN_API_BASE_URL=
MALWARE_SCAN_API_KEY=

# PWA push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Operations
ERROR_TRACKING_PROVIDER=none
ERROR_TRACKING_DSN=
METRICS_PROVIDER=none
HEALTH_DETAILS_TOKEN=
BACKUP_ENCRYPTION_KEY=
BACKUP_RETENTION_DAYS=30
