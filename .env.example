# Application
NODE_ENV=
APP_ENV=
APP_URL=http://localhost:5000
APP_PORT=5000
NEXT_PUBLIC_APP_URL=http://localhost:5000
LOG_LEVEL=

# Database
DATABASE_URL=
DATABASE_DIRECT_URL=

# Redis / queues
REDIS_URL=
QUEUE_PREFIX=
WORKER_CONCURRENCY=

# Authentication and cryptography
AUTH_SECRET=
SESSION_COOKIE_NAME=
SESSION_ABSOLUTE_TTL_SECONDS=
SESSION_IDLE_TTL_SECONDS=
OTP_TTL_SECONDS=
OTP_MAX_ATTEMPTS=
PASSWORD_PEPPER=
NATIONAL_ID_HMAC_KEY=
PII_ENCRYPTION_KEY=
PII_ENCRYPTION_KEY_VERSION=

# Development seed (never seed development accounts in production)
ENABLE_DEVELOPMENT_SEED=
SEED_SUPER_ADMIN_MOBILE=
SEED_SUPER_ADMIN_INITIAL_PASSWORD=
SEED_SUPER_ADMIN_FORCE_PASSWORD_CHANGE=

# Identity verification
IDENTITY_PROVIDER=mock
IDENTITY_API_BASE_URL=
IDENTITY_API_KEY=

# Payments
PAYMENT_PROVIDER=mock
PAYMENT_API_BASE_URL=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=
PLATFORM_PAYMENT_MERCHANT_ID=

# SMS / Kavenegar
SMS_PROVIDER=mock
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=
KAVENEGAR_BOOKING_TEMPLATE=
KAVENEGAR_REMINDER_TEMPLATE=
KAVENEGAR_ATTENDANCE_TEMPLATE=

# Maps / Neshan
MAP_PROVIDER=mock
NESHAN_API_BASE_URL=
NESHAN_API_KEY=
NEXT_PUBLIC_NESHAN_MAP_KEY=

# Object storage (MinIO locally, S3-compatible in production)
STORAGE_PROVIDER=minio
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=
S3_PUBLIC_MEDIA_BUCKET=
S3_PRIVATE_DOCUMENTS_BUCKET=
S3_CONSULTATION_BUCKET=
S3_REVIEW_MEDIA_BUCKET=
S3_PORTFOLIO_MEDIA_BUCKET=
S3_SUPPORT_ATTACHMENTS_BUCKET=
S3_TEMPORARY_UPLOADS_BUCKET=
SIGNED_URL_TTL_SECONDS=

# Malware scanning
MALWARE_SCAN_PROVIDER=mock
MALWARE_SCAN_API_BASE_URL=
MALWARE_SCAN_API_KEY=

# PWA push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Operations
ERROR_TRACKING_PROVIDER=none
ERROR_TRACKING_DSN=
METRICS_PROVIDER=none
HEALTH_DETAILS_TOKEN=
BACKUP_ENCRYPTION_KEY=
BACKUP_RETENTION_DAYS=
