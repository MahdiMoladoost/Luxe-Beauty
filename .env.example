# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL connection. Never commit a real password.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/luxe_beauty?sslmode=require

# Session and encryption secrets. Generate strong random values in the deployment secret manager.
SESSION_SECRET=replace-with-at-least-32-random-bytes
DATA_ENCRYPTION_KEY=replace-with-a-managed-encryption-key

# SMS / OTP provider
SMS_PROVIDER=provider-name
SMS_API_KEY=replace-in-secret-manager
SMS_SENDER=replace-with-approved-sender

# Payment gateway
PAYMENT_GATEWAY=provider-name
PAYMENT_MERCHANT_ID=replace-in-secret-manager
PAYMENT_CALLBACK_URL=http://localhost:3000/api/payments/callback

# Private object storage for salon documents and user uploads
OBJECT_STORAGE_ENDPOINT=https://storage.example.com
OBJECT_STORAGE_BUCKET=luxe-beauty
OBJECT_STORAGE_ACCESS_KEY=replace-in-secret-manager
OBJECT_STORAGE_SECRET_KEY=replace-in-secret-manager

# Map provider
NEXT_PUBLIC_MAP_PROVIDER=provider-name
NEXT_PUBLIC_MAP_KEY=replace-with-public-restricted-key
MAP_SERVER_KEY=replace-in-secret-manager

# Optional transactional email and observability
EMAIL_API_KEY=replace-in-secret-manager
ERROR_TRACKING_DSN=
